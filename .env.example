# WordPress Configuration
# Get these from your WordPress blog's admin panel
# WARNING: These are sensitive credentials - DO NOT commit .env file to repository!

# WordPress REST API Base URL
WP_BASE_URL=https://yourblog.com/wp-json/wp/v2

# WordPress Admin Credentials (HTTP Basic Auth)
WP_USERNAME=your_wordpress_password

# Site Configuration
SITE_URL=https://yourusername.github.io/science-blog
SITE_NAME=Psychology & Neuroscience Science Blog
SITE_DESCRIPTION=Multilingual science blog covering psychology and neuroscience research
SITE_AUTHOR=Juan Moisés de la Serna
SITE_AUTHOR_EMAIL=your_email@example.com

# GitHub Configuration (optional for CI/CD)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=yourusername/science-blog
GITHUB_BRANCH=main

# Content Generation Settings
BATCH_SIZE=100

# Language Configuration
ENABLED_LANGUAGES=eng,spa,fra,deu,ita,por,nld,pol,rus

# SEO Configuration
ENABLE_SITEMAP=true
ENABLE_ROBOTS=true
ROBOTS_ALLOW_CRAWL=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/site_builder.log

# Server Configuration
REQUEST_TIMEOUT=30
RETRY_ATTEMPTS=3
RETRY_DELAY=5

# Security Configuration
FORCE_HTTPS=true
VERIFY_SSL=true

# Performance Configuration
CONCURRENT_REQUESTS=3
USE_CACHE=true
CACHE_DURATION=86400
